{
  "name": "deepfake-shield",
  "version": "0.2.0",
  "description": "Chrome extension that detects AI-generated images on Instagram using a local ONNX model + Content Credentials (C2PA). No data sent anywhere.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.3",
    "onnxruntime-web": "^1.21.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "typescript": "^5.4.5",
    "vite": "^5.4.19",
    "vite-plugin-static-copy": "^1.0.6"
  }
}
